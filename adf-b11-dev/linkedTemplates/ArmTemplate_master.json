			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_5.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"TumblingWindow_Trigger_properties_pipeline_parameters_StartDate": {
						"value": "[parameters('TumblingWindow_Trigger_properties_pipeline_parameters_StartDate')]"
					},
					"TumblingWindow_Trigger_properties_pipeline_parameters_EndDate": {
						"value": "[parameters('TumblingWindow_Trigger_properties_pipeline_parameters_EndDate')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adf-b11-dev_ArmTemplate_4')]"
			]
		}
	]
}